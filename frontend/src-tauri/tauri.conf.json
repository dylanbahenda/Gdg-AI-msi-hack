{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentilo",
  "version": "0.1.0",
  "identifier": "com.pietrosaveri.seld",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sentilo",
        "width": 760,
        "height": 510,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/seld-pipeline"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": false,
      "all": false,
      "sidecar": true,
      "scope": [
        { "name": "seld-pipeline", "sidecar": true }
      ]
    }
  }
}
